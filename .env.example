# Database Configuration
# You can use MONGO_URL or DATABASE_URL interchangeably
DB_NAME=velora
MONGO_URL=mongodb+srv://...
DATABASE_URL=mongodb+srv://...

# Authentication Secrets
# Secure random string used to encrypt JWT sessions
AUTH_SECRET=your_auth_secret_here

# Resend Email Provider Configuration
RESEND_API_KEY=re_...
EMAIL_FROM=ATELIER VELORA <noreply@yourverifieddomain.com>

# NextAuth Configuration (Optional, if using NextAuth in future)
NEXTAUTH_URL=http://localhost:3000

# Razorpay Payment Gateway (Optional for payments)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
